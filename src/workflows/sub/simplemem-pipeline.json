{
  "name": "simplemem-pipeline",
  "version": "1.0",
  "description": "SimpleMem sub-workflow: sliding window → density gating → fact extraction → semantic synthesis. Implements SimpleMem paper §2 as composable atomic stages.",
  "entry": "window",
  "stages": [
    {
      "id": "window",
      "module": "SlidingWindow",
      "config": { "windowSize": 5, "windowOverlap": 2 },
      "next": "gate"
    },
    {
      "id": "gate",
      "module": "DensityGate",
      "config": { "useLLM": true, "minFactCount": 2 },
      "next": "extract"
    },
    {
      "id": "extract",
      "module": "FactExtractor",
      "config": { "maxFactsPerChunk": 8 },
      "next": "synthesize"
    },
    {
      "id": "synthesize",
      "module": "SemanticSynthesis",
      "config": { "synthesisThreshold": 0.82 }
    }
  ]
}
