{
  "name": "clarification-pipeline",
  "version": "1.0",
  "description": "Clarification pipeline pattern: multi-turn user clarification → dual-source retrieval → reconciled generation. Extracted from priha-fusion.json.",
  "entry": "clarify_user",
  "stages": [
    {
      "id": "clarify_user",
      "module": "MultiTurnClarifier",
      "config": { "maxTurns": 5, "complexityGate": true },
      "next": "clarify_llm"
    },
    {
      "id": "clarify_llm",
      "module": "QueryClarifier",
      "config": { "maxClarificationDepth": 2, "maxSubQueries": 3 },
      "next": "websearch"
    },
    {
      "id": "websearch",
      "module": "WebSearchAgent",
      "config": { "searchProvider": "none", "maxResults": 5 },
      "next": "reconcile"
    },
    {
      "id": "reconcile",
      "module": "DualSourceFusion",
      "config": { "localWeight": 0.6, "maxContextChars": 6000 },
      "next": "generate"
    },
    {
      "id": "generate",
      "module": "AnswerGenerator",
      "config": { "enableDualSource": true, "maxContextTokens": 7000 },
      "next": "validate"
    },
    {
      "id": "validate",
      "module": "HallucinationValidator",
      "config": {},
      "next": "cite"
    },
    {
      "id": "cite",
      "module": "CitationInjector",
      "config": { "style": "inline", "maxCitations": 6 }
    }
  ]
}
