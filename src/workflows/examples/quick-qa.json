{
  "name": "quick-qa",
  "version": "2.0",
  "description": "Minimal QA pipeline using sub-workflows: query → embed → hybrid retrieval (sub-workflow) → PriHA fusion (sub-workflow). Fastest path from question to answer with hallucination validation.",
  "entry": "translate",
  "stages": [
    {
      "id": "translate",
      "module": "QueryTranslator",
      "config": {
        "techniques": ["hyde"],
        "useLLM": true
      },
      "next": "embed"
    },
    {
      "id": "embed",
      "module": "Embedder",
      "config": {
        "provider": "ollama",
        "model": "nomic-embed-text"
      },
      "next": "retrieve"
    },
    {
      "id": "retrieve",
      "module": "SubWorkflow",
      "workflowRef": "src/workflows/sub/hybrid-retrieval.json",
      "inputMap": { "query": "query" },
      "outputMap": { "retrievalResult": "retrievalResult", "graphContext": "graphContext" },
      "config": {},
      "next": "fuse"
    },
    {
      "id": "fuse",
      "module": "SubWorkflow",
      "workflowRef": "src/workflows/sub/priha-fusion.json",
      "inputMap": { "query": "query", "retrievalResult": "retrievalResult" },
      "outputMap": { "finalAnswer": "finalAnswer", "sources": "sources", "confidence": "confidence" }
    }
  ],
  "globalConfig": {
    "llmProvider": "ollama",
    "llmModel": "qwen3.5:9b",
    "embeddingProvider": "ollama",
    "embeddingModel": "nomic-embed-text",
    "logLevel": "info"
  }
}
