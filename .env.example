# MemFlow Environment Configuration
#
# Copy to .env and adjust values. Bun auto-loads .env files.

# ---------------------------------------------------------------------------
# LLM / Embeddings (Ollama — default)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:4b
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# Or use OpenRouter
# OPENROUTER_API_KEY=sk-or-...
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-3.5-sonnet

# Or use OpenAI
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai

# ---------------------------------------------------------------------------
# Memgraph
# ---------------------------------------------------------------------------
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=memgraph

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Trading Domain — Data Providers (Phase 4)
#
# API keys are optional. When missing, stub data is used automatically.
# Add your keys to enable live market data integration.
# ---------------------------------------------------------------------------
# ALPHA_VANTAGE_API_KEY=your_key_here
# FINNHUB_API_KEY=your_key_here
# MARKET_DATA_CACHE_TTL=900    # seconds (default: 15 min)
# EARNINGS_CACHE_TTL=86400     # seconds (default: 24h)
# SENTIMENT_CACHE_TTL=300      # seconds (default: 5 min)
# TECHNICAL_CACHE_TTL=900      # seconds (default: 15 min)

