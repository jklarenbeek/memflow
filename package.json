{
  "name": "memflow",
  "version": "0.5.0",
  "description": "MemFlow: Self-Improving RAG & Lifelong Memory Workflow Engine — S2 Chunking, LightRAG, SimpleMem, LightMem, StructMem, HERA, PriHA, and AutoResearchClaw",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "bun": "./src/core/index.ts",
      "default": "./dist/core/index.js"
    },
    "./modules/*": {
      "bun": "./src/modules/*/index.ts",
      "default": "./dist/modules/*/index.js"
    }
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit && echo '✅ No type errors'",
    "start:node": "node --loader ts-node/esm src/index.ts",
    "docker:build": "docker build -t memflow -f docker/Dockerfile .",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "keywords": [
    "rag",
    "memory",
    "llm",
    "workflow",
    "langchain",
    "memgraph",
    "s2-chunking",
    "lightrag",
    "simplemem",
    "lightmem",
    "structmem",
    "hera",
    "priha",
    "autoresearch"
  ],
  "author": "MemFlow Contributors",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^0.3.30",
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.40",
    "@langchain/ollama": "^0.1.5",
    "@langchain/openai": "^0.3.17",
    "@langchain/textsplitters": "^1.0.1",
    "@tavily/core": "^0.7.3",
    "hono": "^4.6.20",
    "langchain": "^0.3.15",
    "neo4j-driver": "^5.27.0",
    "prom-client": "^15.1.3",
    "smol-toml": "^1.3.1",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "trustedDependencies": [
    "protobufjs"
  ]
}