{
  "name": "memflow",
  "version": "0.5.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "MemFlow: Self-Improving RAG & Lifelong Memory Workflow Engine — S2 Chunking, LightRAG, SimpleMem, LightMem, StructMem, HERA, PriHA, and AutoResearchClaw",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "bun": "./src/core/index.ts",
      "default": "./dist/core/index.js"
    },
    "./modules/*": {
      "bun": "./src/modules/*/index.ts",
      "default": "./dist/modules/*/index.js"
    },
    "./gmpl": {
      "bun": "./src/gmpl/index.ts",
      "default": "./dist/gmpl/index.js"
    }
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit && echo '✅ No type errors'",
    "start:node": "node --loader ts-node/esm src/index.ts",
    "docker:build": "docker build -t memflow -f docker/Dockerfile .",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "keywords": [
    "rag",
    "memory",
    "llm",
    "workflow",
    "langchain",
    "memgraph",
    "s2-chunking",
    "lightrag",
    "simplemem",
    "lightmem",
    "structmem",
    "hera",
    "priha",
    "autoresearch"
  ],
  "author": "MemFlow Contributors",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "@langchain/openrouter": "^0.2.4",
    "@langchain/textsplitters": "^1.0.1",
    "@memflow/shared": "workspace:*",
    "@openrouter/sdk": "^0.12.28",
    "@tavily/core": "^0.7.3",
    "fflate": "^0.8.2",
    "hono": "^4.12.17",
    "langchain": "^1.3.5",
    "neo4j-driver": "^6.0.1",
    "officeparser": "^6.1.1",
    "prom-client": "^15.1.3",
    "smol-toml": "^1.6.1",
    "unpdf": "^1.6.2",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@hono/node-server": "^2.0.1",
    "ml-matrix": "^6.12.2",
    "ml-pca": "^4.1.1",
    "ml-kmeans": "^7.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "trustedDependencies": [
    "protobufjs"
  ]
}